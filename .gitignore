# ============================================================
# Eclipse Frontier - .gitignore
# Godot 4.x
# ============================================================

# Godot 4+ specific ignores
.godot/
.import/
export.cfg
export_presets.cfg.bak

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# System / Editor files
.DS_Store
Thumbs.db
*.tmp
*.bak
*.log
*.swp
*~

# Build output
build/
android/build/
android/.gradle/
*.apk
*.aab
*.exe
*.pck
*.zip

# Keystores (security - never commit signing keys)
*.keystore
*.jks
!debug.keystore

# IDE files
.vscode/
.idea/
*.code-workspace

# Codespaces / devcontainer cache
.devcontainer/.cache/

# OS generated files
ehthumbs.db
Desktop.ini

# Node (in case any tooling scripts are added later)
node_modules/

# Environment files (never commit secrets)
.env
.env.local
