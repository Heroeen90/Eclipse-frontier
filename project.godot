; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] # Section headers.
;   key=value # Key-value pairs that make up the section contents.
;
; Most of the time you don't need to edit this file by hand,
; use the project-settings dialog instead.

config_version=5

[application]

config/name="Eclipse Frontier"
config/version="0.1.0"
config/description="An expandable open-world resource-gathering and base-building game built with Godot 4."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "Mobile")
config/icon="res://assets/sprites/ui/icon.png"

[autoload]

Logger="*res://scripts/core/logger.gd"
EventBus="*res://scripts/core/event_bus.gd"
ErrorHandler="*res://scripts/core/error_handler.gd"
GameManager="*res://scripts/core/game_manager.gd"
ResourceManager="*res://scripts/core/resource_manager.gd"
InventoryManager="*res://scripts/inventory/inventory_manager.gd"
BuildingManager="*res://scripts/world/building_manager.gd"
QuestManager="*res://scripts/quests/quest_manager.gd"
SaveSystem="*res://scripts/save/save_system.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1
window/dpi/allow_hidpi=true

